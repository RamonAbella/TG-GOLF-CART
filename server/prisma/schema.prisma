generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("customer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  listings  MarketplaceListing[]
}

model Cart {
  id          String   @id @default(cuid())
  name        String
  model       String
  year        Int
  capacity    Int
  type        String
  color       String
  description String
  features    String
  images      String
  dailyRate   Float
  weeklyRate  Float
  monthlyRate Float
  status      String   @default("available")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id           String   @id @default(cuid())
  userId       String?
  cartId       String
  guestName    String
  guestEmail   String
  guestPhone   String
  startDate    DateTime
  endDate      DateTime
  duration     Int
  durationType String
  totalPrice   Float
  deposit      Float
  status       String   @default("pending")
  paymentId    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
  cart Cart  @relation(fields: [cartId], references: [id])
}

model ServiceRequest {
  id            String    @id @default(cuid())
  type          String
  customerName  String
  customerEmail String
  customerPhone String
  cartMake      String?
  cartModel     String?
  cartYear      Int?
  description   String
  status        String    @default("pending")
  scheduledAt   DateTime?
  estimatedPrice Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MarketplaceListing {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  make        String
  model       String
  year        Int
  condition   String
  price       Float
  description String
  features    String
  images      String
  location    String
  status      String   @default("active")
  sellerName  String
  sellerEmail String
  sellerPhone String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Testimonial {
  id       String   @id @default(cuid())
  name     String
  rating   Int
  text     String
  service  String
  date     DateTime @default(now())
  approved Boolean  @default(true)
}

model ServiceOffering {
  id          String   @id @default(cuid())
  type        String   @unique
  title       String
  shortDesc   String
  description String
  price       String
  benefits    String
  image       String?
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String
  section   String   @default("general")
  updatedAt DateTime @updatedAt
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  service       String   @default("rental")
  notes         String?
  preferredDate String?
  status        String   @default("new")
  source        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CRMCustomer {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  email       String?
  city        String?
  cartModel   String?
  voltage     String?
  status      String    @default("lead")
  notes       String?
  installDate String?
  warrantyEnd String?
  source      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invoices    Invoice[]
}

model Invoice {
  id            String      @id @default(cuid())
  invoiceNum    String      @unique
  customerId    String?
  customer      CRMCustomer? @relation(fields: [customerId], references: [id])
  customerName  String
  customerEmail String?
  date          DateTime    @default(now())
  dueDate       DateTime?
  status        String      @default("draft")
  subtotal      Float       @default(0)
  taxRate       Float       @default(0)
  taxAmount     Float       @default(0)
  total         Float       @default(0)
  notes         String?
  lineItems     String      @default("[]")
  taxEnabled    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  category    String   @default("other")
  description String
  vendor      String?
  amount      Float
  receiptUrl  String?
  customerId  String?
  notes       String?
  createdAt   DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  sessionId String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String   @default("")
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
